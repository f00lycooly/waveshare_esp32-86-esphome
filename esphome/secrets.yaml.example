# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit real credentials.

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# 32-byte base64 API encryption key.
# Generate one at https://esphome.io/components/api.html (or: openssl rand -base64 32)
# and paste it below, replacing the placeholder.
esphome_api_key: "<paste-your-base64-key>"
